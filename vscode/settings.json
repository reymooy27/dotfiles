{
  //for performance
  // Disable the file watcher for heavy folders (Crucial for performance)
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/env/**": true,
    "**/venv/**": true,
    "**/dist/**": true,
  },
  // Stop search from indexing non-source files
  "search.exclude": {
    "**/node_modules": true,
    "**/bower_components": true,
    "**/env": true,
    "**/venv": true,
  },
  "search.followSymlinks": false,

  //vim
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.sneak": true,
  "vim.sneakUseIgnorecaseAndSmartcase": true,
  // "vim.scroll": 20,
  "vim.changeWordIncludesWhitespace": true,
  "vim.easymotion": true,
  "vim.autoindent": true,
  "vim.incsearch": true,
  "vim.showcmd": true,
  "vim.foldfix": true,
  "vim.useSystemClipboard": true,
  "vim.showMarksInGutter": true,
  "vim.searchMatchColor": "white",
  "vim.highlightedyank.enable": true,
  "vim.highlightedyank.duration": 200,
  "vim.highlightedyank.color": "rgba(240, 0, 0, 0.5)",
  "vim.sneakReplacesF": true,
  "vim.startofline": true,
  "vim.surround": true,
  "vim.matchpairs": "(:),{:},[:]",
  "vim.wrapscan": true,
  "vim.scroll": 0,
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-u>": true,
    "<C-s>": false,
    "<C-z>": false,
  },
  "vim.normalModeKeyBindings": [],
  "vim.normalModeKeyBindingsNonRecursive": [
    // {
    //     "before": [
    //         "<leader>",
    //         "t"
    //     ],
    //     "commands": [
    //         "editor.emmet.action.matchTag"
    //     ]
    // },

    {
      "before": ["<S-u>"],
      "after": ["<C-r>"],
    },
    {
      "before": ["<leader>", "p"],
      "commands": ["workbench.action.showCommands"],
    },
    {
      "before": ["w", "e"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": ["e", "w"],
      "commands": ["workbench.action.files.save"],
    },
    {
      "before": ["<C-a>"],
      "after": ["G", "V", "g", "g"],
    },
    {
      "before": ["]", "e"],
      "commands": ["editor.action.marker.nextInFiles"],
      "silent": true,
    },
    {
      "before": ["[", "e"],
      "commands": ["editor.action.marker.prevInFiles"],
      "silent": true,
    },
  ],
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": ["k", "j"],
      "after": ["<esc>"],
    },
    {
      "before": ["j", "k"],
      "after": ["<esc>"],
    },
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["i", "i"],
      "after": ["<esc>"],
    },
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["i", "i"],
      "after": ["<esc>"],
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"],
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"],
    },
  ],

  //editor
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "editor.formatOnSave": true,
  "editor.tabSize": 4,
  "editor.wordWrapColumn": 80,
  "editor.hover.above": false,
  "editor.hover.sticky": true,
  "editor.hover.enabled": false,
  "editor.hover.delay": 0,
  "editor.codeActionsOnSave": {
    "source.addMissingImports.ts": "always",
    "source.fixAll.ts": "always",
    "source.sortImports": "always",
  },
  "editor.lineNumbers": "relative",
  "editor.cursorBlinking": "solid",
  "editor.foldingStrategy": "indentation",
  "editor.fontLigatures": false,
  "editor.autoIndentOnPaste": true,
  "editor.find.cursorMoveOnType": true,
  "editor.cursorSmoothCaretAnimation": "off",
  "editor.foldingHighlight": true,
  "editor.minimap.enabled": false,
  "editor.roundedSelection": true,
  "editor.rulers": [90],
  "editor.smoothScrolling": false,
  "editor.linkedEditing": true,
  "editor.fontSize": 14,
  "editor.codeLens": false,
  "editor.lightbulb.enabled": "off",
  "editor.guides.indentation": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "auto",
  "editor.overviewRulerBorder": false,
  "editor.showUnused": true,
  "editor.renderWhitespace": "none",

  "breadcrumbs.enabled": false,

  "git.autofetch": true,
  // "prisma.showPrismaDataPlatformNotification": false,
  "git.confirmSync": false,
  "git.showCommitInput": false,
  "git.blame.statusBarItem.enabled": true,

  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "accessibility.signals.terminalBell": {
    "sound": "off",
  },
  "vim.commandLineModeKeyBindingsNonRecursive": [],
  "terminal.explorerKind": "external",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.hideOnStartup": "always",
  "terminal.integrated.suggest.cdPath": "relative",
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.suggest.runOnEnter": "exactMatch",
  "terminal.integrated.suggest.quickSuggestions": {
    "commands": "on",
    "arguments": "on",
    "unknown": "off",
  },
  "terminal.integrated.suggest.providers": {
    "lsp": true,
    "vscode.terminal-suggest": true,
  },

  "workbench.tree.renderIndentGuides": "onHover",
  "workbench.list.smoothScrolling": false,
  "workbench.activityBar.location": "bottom",
  "workbench.editor.restoreViewState": false,
  "workbench.editor.showTabs": "multiple",
  "workbench.startupEditor": "readme",
  "workbench.tips.enabled": false,
  "workbench.activityBar.orientation": "vertical",
  // "workbench.iconTheme": "material-icon-theme",
  "workbench.sideBar.location": "left",
  // "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": false,
  "workbench.view.alwaysShowHeaderActions": true,
  "workbench.settings.showAISearchToggle": false,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.highlightModifiedTabs": false,
  "workbench.editor.showIcons": false,
  "workbench.remoteIndicator.showExtensionRecommendations": false,
  "workbench.colorTheme": "Tokyo Night",

  "window.density.editorTabHeight": "compact",
  "window.confirmBeforeClose": "never",
  "window.confirmSaveUntitledWorkspace": false,
  "window.menuBarVisibility": "toggle",
  "window.commandCenter": false,
  "window.title": "${folderName} (${activeRepositoryBranchName}) - ${activeEditorShort} ${dirty}",
  "window.customTitleBarVisibility": "windowed",
  "window.titleBarStyle": "custom",
  "window.dialogStyle": "custom",

  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmDelete": false,

  "files.trimTrailingWhitespace": true,
  "files.restoreUndoStack": false,
  "files.insertFinalNewline": true,

  "extensions.autoUpdate": true,
  "extensions.ignoreRecommendations": true,
  "liveServer.settings.donotShowInfoMsg": true,
  "diffEditor.codeLens": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "python.createEnvironment.trigger": "off",
  "scm.diffDecorations": "all",
  "geminicodeassist.project": "jittery-charge-9fpch",
  "typescript.disableAutomaticTypeAcquisition": true,
  "python.analysis.exclude": ["**/node_modules", "**/venv", "**/.git"],
  "errorLens.delay": 500,
}

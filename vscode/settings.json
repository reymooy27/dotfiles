{
  "editor.fontFamily": "JetBrainsMono Nerd Font",
  "vim.leader": "<space>",
  "vim.hlsearch": true,
  "vim.sneak": true,
  "vim.sneakUseIgnorecaseAndSmartcase": true,
  // "vim.scroll": 20,
  "vim.changeWordIncludesWhitespace": true,
  "vim.easymotion": true,
  "vim.incsearch": true,
  "vim.foldfix": true,
  "vim.useSystemClipboard": true,
  "vim.showMarksInGutter": true,
  "vim.searchMatchColor": "white",
  "vim.highlightedyank.color": "rgba(250, 225, 225, 0.5)",
  "vim.sneakReplacesF": true,
  "vim.startofline": true,
  "vim.surround": true,
  "vim.matchpairs": "(:),{:},[:]",
  "editor.formatOnSave": true,
  "editor.tabSize": 2,
  "editor.wordWrapColumn": 80,
  "editor.hover.above": false,
  "editor.hover.sticky": true,
  "editor.codeActionsOnSave": {
    "source.addMissingImports.ts": "always",
    "source.fixAll.ts": "always",
    "source.sortImports": "always"
  },
  "editor.lineNumbers": "relative",
  "vim.handleKeys": {
    "<C-d>": true,
    "<C-u>": true,
    "<C-s>": false,
    "<C-z>": false
  },
  "vim.normalModeKeyBindings": [],
  "vim.normalModeKeyBindingsNonRecursive": [
    // {
    //     "before": [
    //         "<leader>",
    //         "t"
    //     ],
    //     "commands": [
    //         "editor.emmet.action.matchTag"
    //     ]
    // },

    {
      "before": ["<S-u>"],
      "after": ["<C-r>"]
    },
    {
      "before": ["<leader>", "p"],
      "commands": ["workbench.action.showCommands"]
    },
    {
      "before": ["w", "e"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["e", "w"],
      "commands": ["workbench.action.files.save"]
    },
    {
      "before": ["<C-a>"],
      "after": ["G", "V", "g", "g"]
    },
    {
      "before": ["]", "e"],
      "commands": ["editor.action.marker.nextInFiles"],
      "silent": true
    },
    {
      "before": ["[", "e"],
      "commands": ["editor.action.marker.prevInFiles"],
      "silent": true
    }
  ],
  "vim.insertModeKeyBindingsNonRecursive": [
    {
      "before": ["k", "j"],
      "after": ["<esc>"]
    },
    {
      "before": ["j", "k"],
      "after": ["<esc>"]
    }
  ],
  "vim.visualModeKeyBindingsNonRecursive": [
    {
      "before": ["i", "i"],
      "after": ["<esc>"]
    }
  ],
  "vim.visualModeKeyBindings": [
    {
      "before": ["i", "i"],
      "after": ["<esc>"]
    },
    {
      "before": [">"],
      "commands": ["editor.action.indentLines"]
    },
    {
      "before": ["<"],
      "commands": ["editor.action.outdentLines"]
    }
  ],
  "explorer.confirmDelete": false,
  "window.confirmBeforeClose": "never",
  "window.confirmSaveUntitledWorkspace": false,
  "editor.fontLigatures": false,
  "editor.minimap.enabled": false,
  "breadcrumbs.enabled": false,
  "git.autofetch": true,
  "prisma.showPrismaDataPlatformNotification": false,
  "git.confirmSync": false,
  "editor.linkedEditing": true,
  "editor.fontSize": 14,
  "terminal.integrated.fontFamily": "JetBrainsMono Nerd Font",
  "accessibility.signals.terminalBell": {
    "sound": "off"
  },
  "accessibilityjsignals.terminalCommandFailed": {
    "announcement": "off",
    "sound": "off"
  },
  "vim.commandLineModeKeyBindingsNonRecursive": [],
  "terminal.explorerKind": "external",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.copyOnSelection": true,
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "workbench.activityBar.location": "top",
  "workbench.editor.showTabs": "multiple",
  "window.density.editorTabHeight": "compact",
  "window.menuBarVisibility": "toggle",
  "window.commandCenter": false,
  "workbench.startupEditor": "readme",
  "workbench.tips.enabled": false,
  "explorer.compactFolders": false,
  "explorer.confirmDragAndDrop": false,
  "editor.codeLens": false,
  "editor.lightbulb.enabled": "off",
  // "editor.hover.enabled": false,
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "editor.guides.indentation": false,
  "editor.scrollbar.horizontal": "hidden",
  "editor.scrollbar.vertical": "auto",
  "editor.overviewRulerBorder": false,
  "workbench.activityBar.orientation": "vertical",
  // "workbench.iconTheme": "material-icon-theme",
  "workbench.sideBar.location": "left",
  // "workbench.sideBar.location": "right",
  "workbench.statusBar.visible": false,
  "window.title": "${folderName} (${activeRepositoryBranchName}) - ${activeEditorShort} ${dirty}",
  "extensions.autoUpdate": true,
  "vim.wrapscan": true,
  "extensions.ignoreRecommendations": true,
  "workbench.remoteIndicator.showExtensionRecommendations": false,
  "liveServer.settings.donotShowInfoMsg": true,
  "window.customTitleBarVisibility": "windowed",
  "window.titleBarStyle": "custom",
  "gitlens.ai.model": "vscode",
  "gitlens.ai.gitkraken.model": "gemini:gemini-2.0-flash",
  "diffEditor.codeLens": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "workbench.settings.showAISearchToggle": false,
  "workbench.editor.closeOnFileDelete": true,
  "workbench.editor.enablePreviewFromCodeNavigation": true,
  "workbench.editor.highlightModifiedTabs": false,
  "workbench.editor.showIcons": false,
  "window.dialogStyle": "custom",
  "diffEditor.ignoreTrimWhitespace": false,
  "diffEditor.hideUnchangedRegions.enabled": true,
  "python.createEnvironment.trigger": "off",
  "gitlens.ai.vscode.model": "copilot:gpt-4.1"
}
